# ---- App Settings ----

# Path to the OpenDKIM configuration directory (contains KeyTable, SigningTable, TrustedHosts, keys/)
OPENDKIM_CONFIG_DIR=/etc/opendkim

# Path to the main opendkim.conf file
OPENDKIM_CONF=/etc/opendkim.conf

# PID file location (for sending SIGHUP to reload)
OPENDKIM_PID_FILE=/run/opendkim/opendkim.pid

# ---- Docker Settings ----

# UID/GID of the opendkim user on the host (find with: id opendkim)
APP_UID=113
APP_GID=113

# Port to expose the dashboard on
DASHBOARD_PORT=3000

# Host path to the opendkim run directory (contains PID file)
OPENDKIM_RUN_DIR=/run/opendkim
